<Window x:Class="Task6.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task6"
        mc:Ignorable="d"
        Title="OrdersWindow" Height="450" Width="800">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Все зарегистрированные заказы" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <DataGrid Grid.Row="1" x:Name="AllOrdersGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionChanged="AllOrdersGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ Заказа" Binding="{Binding Id}" Width="70"/>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding OrderDate, StringFormat=\{0:dd.MM.yyyy\}}" Width="100"/>
                    <DataGridTextColumn Header="Сумма" Binding="{Binding TotalPrice, StringFormat={}{0:N2} руб.}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Border Grid.Column="1" Background="#F5F5F5" CornerRadius="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Детали и редактирование" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

                <StackPanel Grid.Row="1" x:Name="DetailsPanel" Visibility="Collapsed">
                    <TextBlock Text="Номер заказа:" Margin="0,0,0,2" Foreground="Gray"/>
                    <TextBlock x:Name="DetailIdText" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <TextBlock Text="Дата заказа:" Margin="0,0,0,2" Foreground="Gray"/>
                    <TextBlock x:Name="DetailDateText" Margin="0,0,0,10"/>

                    <TextBlock Text="ФИО клиента:" Margin="0,0,0,2" Foreground="Gray"/>
                    <TextBlock x:Name="DetailClientText" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <TextBlock Text="Код подтверждения:" Margin="0,0,0,2" Foreground="Gray"/>
                    <TextBlock x:Name="DetailCodeText" Foreground="DarkGreen" FontWeight="Bold" Margin="0,0,0,15"/>

                    <Separator Margin="0,0,0,15"/>

                    <TextBlock Text="Указать дату доставки:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DeliveryDatePicker" Height="28" Margin="0,0,0,15"/>

                    <TextBlock Text="Статус заказа:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="StatusComboBox" Height="28" Margin="0,0,0,15">
                        <ComboBoxItem Content="новый"/>
                        <ComboBoxItem Content="в обработке"/>
                        <ComboBoxItem Content="готов к выдаче"/>
                        <ComboBoxItem Content="завершен"/>
                        <ComboBoxItem Content="отменен"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Grid.Row="1" x:Name="PlaceholderText" Text="Выберите заказ из списка слева для просмотра деталей и изменения параметров" 
                           VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Foreground="Gray"/>

                <Button Grid.Row="2" x:Name="SaveStatusButton" Content="Сохранить изменения" Click="SaveStatusButton_Click" 
                        Height="35" FontWeight="Bold" Background="#E3F2FD" BorderBrush="#2196F3" Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>
