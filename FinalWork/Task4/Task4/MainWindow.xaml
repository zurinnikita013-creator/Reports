<Window x:Class="Task4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Task4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        
        <ListBox Name="ProductsListBox" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black" BorderThickness="1" Margin="5" Padding="10" CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Margin="0,0,0,3"/>
                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBlock Text="Производитель: " Foreground="Gray"/>
                                    <TextBlock Text="{Binding Manufacturer}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Цена: " Foreground="Gray"/>
                                    <TextBlock Text="{Binding Price, StringFormat='{}{0:C}'}"/>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="1" 
                                    Content="Заказать" 
                                    Width="80" 
                                    Height="30" 
                                    VerticalAlignment="Center" 
                                    Margin="10,0,0,0"
                                    Click="OrderButton_Click"
                                    Tag="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
